# Function to load data from file
def load_data(filename):
    last_names = []
    scores = []

    file = open(filename, "r")

    for line in file:
        data = line.split()

        last_name = data[0]
        score = int(data[1])

        last_names.append(last_name)
        scores.append(score)

    file.close()

    return last_names, scores


